# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sorak:sorak@localhost:5432/sorak?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_xxxxxxxx
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_yyyyyy
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Seed ──────────────────────────────────────────────────────────────────
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@sorak.local
SEED_ADMIN_PASSWORD=Admin@12345

# ── OTP (Iter 4) ──────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_WRONG_ATTEMPTS=5
OTP_LOCK_MINUTES=15
OTP_DEV_HARDCODE=123456

# ── Storage (MinIO/S3) ────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sorak-dev

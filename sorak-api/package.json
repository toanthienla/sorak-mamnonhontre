{
  "name": "sorak-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sorak API — Express.js backend (legacy NestJS at sorak-api-nestjs)",
  "scripts": {
    "dev": "node --watch --env-file=.env src/server.js | pino-pretty",
    "start": "node --env-file=.env src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env prisma/seed.js",
    "db:seed:demo": "node --env-file=.env prisma/seed-demo.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.9",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.8.4",
    "prisma": "^6.19.3"
  }
}

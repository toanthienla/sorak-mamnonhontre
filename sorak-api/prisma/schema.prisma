model AssessmentContentAdditionRequest {
  request_id           Int       @id @default(autoincrement())
  request_code         String    @unique @db.VarChar(30)
  request_type         String    @db.VarChar(30)
  status               String    @default("PENDING") @db.VarChar(20)
  proposed_name        String?   @db.VarChar(1000)
  proposed_description String?   @db.VarChar(500)
  proposed_reason      String?   @db.VarChar(1000)
  proposed_criteria    Json?
  age_group_id         Int?
  development_field_id Int?
  subject_id           Int?
  theme_id             Int?
  topic_id             Int?
  criterion_id         Int?
  requester_id         Int
  requester_teacher_id Int
  requester_class_id   Int?
  reviewed_by          Int?
  reviewed_at          DateTime?
  review_note          String?   @db.VarChar(1000)
  cancelled_at         DateTime?
  cancelled_by         Int?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  age_group         AssessmentAgeGroup?                     @relation(fields: [age_group_id], references: [assessment_age_group_id])
  development_field DevelopmentField?                       @relation(fields: [development_field_id], references: [development_field_id])
  subject           AssessmentSubject?                      @relation(fields: [subject_id], references: [assessment_subject_id])
  theme             AssessmentTheme?                        @relation(fields: [theme_id], references: [assessment_theme_id])
  topic             AssessmentTopic?                        @relation(fields: [topic_id], references: [assessment_topic_id])
  criterion         AssessmentCriterion?                    @relation(fields: [criterion_id], references: [assessment_criterion_id])
  requester         Account                                 @relation("AssessmentContentRequestRequester", fields: [requester_id], references: [account_id])
  requester_teacher Teacher                                 @relation(fields: [requester_teacher_id], references: [teacher_id])
  requester_class   Class?                                  @relation(fields: [requester_class_id], references: [class_id])
  reviewer          Account?                                @relation("AssessmentContentRequestReviewer", fields: [reviewed_by], references: [account_id])
  canceller         Account?                                @relation("AssessmentContentRequestCanceller", fields: [cancelled_by], references: [account_id])
  created_records   AssessmentContentRequestCreatedRecord[]

  @@index([request_type])
  @@index([status])
  @@index([requester_id])
  @@index([requester_teacher_id])
  @@index([requester_class_id])
  @@index([age_group_id])
  @@index([development_field_id])
  @@index([subject_id])
  @@index([theme_id])
  @@index([topic_id])
  @@index([criterion_id])
  @@index([created_at])
  @@map("assessment_content_addition_requests")
}

model AssessmentContentRequestCreatedRecord {
  id          Int      @id @default(autoincrement())
  request_id  Int
  record_type String   @db.VarChar(30)
  record_id   Int
  created_at  DateTime @default(now())

  request AssessmentContentAdditionRequest @relation(fields: [request_id], references: [request_id], onDelete: Cascade)

  @@index([request_id])
  @@index([record_type, record_id])
  @@map("assessment_content_request_created_records")
}

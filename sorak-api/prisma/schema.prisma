// Prisma schema — Sorak API Option A
// accounts = auth only | teachers = GV/BGH profile | students = profile + linked account

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── NHÓM 1: Tài khoản & Phân quyền ─────────────────────────────────────────

model Account {
    account_id     Int       @id @default(autoincrement())
    role           String    @db.VarChar(20) // BGH | GV | PH
    password_hash  String    @db.VarChar(255)
    is_active      Boolean   @default(true)
    otp_code       String?   @db.VarChar(10)
    otp_expires_at DateTime?
    deleted_at     DateTime?
    created_at     DateTime  @default(now())
    updated_at     DateTime  @updatedAt

    teacher Teacher?
    student Student?

    created_students Student[] @relation("StudentCreatedBy")
    updated_students Student[] @relation("StudentUpdatedBy")

    requested_transfers ClassTransferRequest[] @relation("TransferRequestedBy")
    reviewed_transfers  ClassTransferRequest[] @relation("TransferReviewedBy")

    @@index([deleted_at])
    @@map("accounts")
}

model Teacher {
    teacher_id      Int       @id @default(autoincrement())
    account_id      Int?      @unique
    full_name       String    @db.VarChar(150)
    email           String    @unique @db.VarChar(150) // login identifier BGH/GV
    phone           String?   @db.VarChar(20)
    gender          String?   @db.VarChar(10)
    date_of_birth   DateTime?
    address         String?   @db.VarChar(500)
    position        String?   @db.VarChar(100) // Giáo viên | Hiệu trưởng | Hiệu phó | Kế toán...
    work_start_date DateTime?
    qualification   String?   @db.VarChar(255)
    work_status     String    @default("Đang làm việc") @db.VarChar(50)
    deleted_at      DateTime?
    created_at      DateTime  @default(now())
    updated_at      DateTime  @updatedAt

    account         Account?       @relation(fields: [account_id], references: [account_id])
    teacher_classes TeacherClass[]

    @@index([deleted_at])
    @@index([email])
    @@map("teachers")
}

// ─── NHÓM 2: Cấu trúc trường ────────────────────────────────────────────────

model SchoolYear {
    school_year_id           Int       @id @default(autoincrement())
    name                     String    @unique @db.VarChar(20)
    start_date               DateTime
    end_date                 DateTime
    status                   String    @default("inactive") @db.VarChar(20)
    deleted_at               DateTime?

    semesters Semester[]
    classes   Class[]
    enrollments StudentEnrollment[]

    class_transfer_requests ClassTransferRequest[]
    outgoing_transfers      OutgoingTransfer[]
    incoming_transfers      IncomingTransfer[]
    health_assessments      HealthAssessment[]
    nutrition_assessments   NutritionAssessment[]

    @@map("school_years")
}

model Semester {
    semester_id     Int      @id @default(autoincrement())
    school_year_id  Int
    semester_number Int
    start_date      DateTime
    end_date        DateTime

    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])

    class_transfer_requests ClassTransferRequest[]

    @@unique([school_year_id, semester_number])
    @@map("semesters")
}

model Class {
    class_id       Int       @id @default(autoincrement())
    class_name     String    @db.VarChar(100)
    school_year_id Int
    age_group      String?   @db.VarChar(30)
    room           String?   @db.VarChar(50)
    created_at     DateTime  @default(now())
    deleted_at     DateTime?

    school_year     SchoolYear          @relation(fields: [school_year_id], references: [school_year_id])
    teacher_classes TeacherClass[]
    enrollments     StudentEnrollment[]

    transfers_from     ClassTransferRequest[] @relation("TransferFromClass")
    transfers_to       ClassTransferRequest[] @relation("TransferToClass")
    outgoing_transfers OutgoingTransfer[]
    incoming_transfers IncomingTransfer[]
    health_assessments HealthAssessment[]
    nutrition_assessments NutritionAssessment[]

    @@index([school_year_id])
    @@index([deleted_at])
    @@map("classes")
}

model TeacherClass {
    teacher_class_id Int       @id @default(autoincrement())
    teacher_id       Int
    class_id         Int
    assigned_at      DateTime  @default(now())
    removed_at       DateTime?

    teacher Teacher @relation(fields: [teacher_id], references: [teacher_id])
    class   Class   @relation(fields: [class_id], references: [class_id])

    @@unique([teacher_id, class_id])
    @@map("teacher_classes")
}

// ─── NHÓM 3: Hồ sơ trẻ ──────────────────────────────────────────────────────

model Student {
    student_id               Int       @id @default(autoincrement())
    account_id               Int?      @unique // nullable — tạo khi cấp tài khoản PH
    student_id_card_number   String    @unique @db.VarChar(20)
    full_name                String    @db.VarChar(150)
    date_of_birth            DateTime
    gender                   String    @db.VarChar(10)
    grade_level              String?   @db.VarChar(30)
    student_status           String    @default("Đang học") @db.VarChar(50)
    enrollment_date          DateTime?
    new_admission_date       DateTime?
    is_new_admission         Boolean   @default(false)
    order_number             Int?
    ethnicity                String?   @db.VarChar(50)
    nationality              String?   @db.VarChar(50)
    religion                 String?   @db.VarChar(50)
    area_type                String?   @db.VarChar(20)
    blood_type               String?   @db.VarChar(5)
    contact_phone            String?   @db.VarChar(20)
    permanent_province       String?   @db.VarChar(100)
    permanent_ward           String?   @db.VarChar(100)
    permanent_address_detail String?   @db.VarChar(500)
    current_address          String?   @db.VarChar(500)
    hometown_province        String?   @db.VarChar(100)
    hometown_ward            String?   @db.VarChar(100)
    birth_place              String?   @db.VarChar(255)
    photo_url                String?   @db.VarChar(500)
    created_by               Int?
    updated_by               Int?
    created_at               DateTime  @default(now())
    updated_at               DateTime  @updatedAt
    deleted_at               DateTime?

    account            Account?  @relation(fields: [account_id], references: [account_id])
    created_by_account Account?  @relation("StudentCreatedBy", fields: [created_by], references: [account_id])
    updated_by_account Account?  @relation("StudentUpdatedBy", fields: [updated_by], references: [account_id])

    parents     Parent[]
    enrollments StudentEnrollment[]

    class_transfer_requests ClassTransferRequest[]
    outgoing_transfers      OutgoingTransfer[]
    incoming_transfers      IncomingTransfer[]
    health_assessments      HealthAssessment[]
    nutrition_assessments   NutritionAssessment[]

    @@index([deleted_at])
    @@index([full_name])
    @@map("students")
}

// ─── NHÓM 4: Phụ huynh ──────────────────────────────────────────────────────

model Parent {
    parent_id    Int      @id @default(autoincrement())
    student_id   Int
    full_name    String   @db.VarChar(150)
    phone        String?  @db.VarChar(20)
    relationship String?  @db.VarChar(50)
    created_at   DateTime @default(now())

    student Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

    @@index([student_id])
    @@map("parents")
}

// ─── NHÓM 5: Phân lớp ───────────────────────────────────────────────────────

model StudentEnrollment {
    enrollment_id  Int       @id @default(autoincrement())
    student_id     Int
    school_year_id Int       // always set — source of truth for year
    class_id       Int?      // nullable — enrolled in year but no class yet
    grade_level    String?   @db.VarChar(30)
    enrolled_date  DateTime  @default(now())
    left_date      DateTime?
    student_status String    @default("Đang học") @db.VarChar(50)

    student     Student    @relation(fields: [student_id], references: [student_id])
    class       Class?     @relation(fields: [class_id], references: [class_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])

    // Unique enforced via raw SQL with NULLS NOT DISTINCT (PG15+) — see migration
    @@index([student_id, school_year_id])
    @@index([class_id])
    @@map("student_enrollments")
}

// ─── NHÓM 6: Chuyển lớp / Chuyển trường ─────────────────────────────────────

model ClassTransferRequest {
    request_id     Int       @id @default(autoincrement())
    student_id     Int
    school_year_id Int
    semester_id    Int? // resolve từ effective_date — phục vụ giới hạn 2 lần/học kỳ (BR-065)
    from_class_id  Int
    to_class_id    Int
    reason         String    @db.VarChar(500)
    effective_date DateTime
    status         String    @default("Pending") @db.VarChar(20) // Pending | Approved | Rejected | Cancelled
    requested_by   Int
    reviewed_by    Int?
    review_note    String?   @db.VarChar(500)
    reviewed_at    DateTime?
    applied_at     DateTime? // null = chưa đổi lớp; cron set khi áp dụng (BR-071)
    created_at     DateTime  @default(now())
    updated_at     DateTime  @updatedAt

    student     Student    @relation(fields: [student_id], references: [student_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])
    semester    Semester?  @relation(fields: [semester_id], references: [semester_id])
    from_class  Class      @relation("TransferFromClass", fields: [from_class_id], references: [class_id])
    to_class    Class      @relation("TransferToClass", fields: [to_class_id], references: [class_id])
    requester   Account    @relation("TransferRequestedBy", fields: [requested_by], references: [account_id])
    reviewer    Account?   @relation("TransferReviewedBy", fields: [reviewed_by], references: [account_id])

    @@index([student_id])
    @@index([school_year_id])
    @@index([status])
    @@map("class_transfer_requests")
}

model OutgoingTransfer {
    transfer_id        Int       @id @default(autoincrement())
    student_id         Int
    school_year_id     Int
    class_id           Int?
    destination_school String    @db.VarChar(255)
    transfer_date      DateTime
    reason             String?   @db.VarChar(500)
    note               String?   @db.VarChar(500)
    status             String    @default("Recorded") @db.VarChar(20) // Recorded | Cancelled
    cancel_reason      String?   @db.VarChar(500)
    created_by         Int?
    updated_by         Int?
    created_at         DateTime  @default(now())
    updated_at         DateTime  @updatedAt
    deleted_at         DateTime?

    student     Student    @relation(fields: [student_id], references: [student_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])
    class       Class?     @relation(fields: [class_id], references: [class_id])

    @@index([student_id])
    @@index([school_year_id])
    @@index([deleted_at])
    @@map("outgoing_transfers")
}

model IncomingTransfer {
    transfer_id     Int       @id @default(autoincrement())
    student_id      Int
    school_year_id  Int
    class_id        Int?
    previous_school String    @db.VarChar(255)
    transfer_date   DateTime
    reason          String?   @db.VarChar(500)
    note            String?   @db.VarChar(500)
    status          String    @default("Recorded") @db.VarChar(20) // Recorded | Cancelled
    cancel_reason   String?   @db.VarChar(500)
    created_by      Int?
    updated_by      Int?
    created_at      DateTime  @default(now())
    updated_at      DateTime  @updatedAt
    deleted_at      DateTime?

    student     Student    @relation(fields: [student_id], references: [student_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])
    class       Class?     @relation(fields: [class_id], references: [class_id])

    @@index([student_id])
    @@index([school_year_id])
    @@index([deleted_at])
    @@map("incoming_transfers")
}

// ─── NHÓM 7: Sức khỏe & Dinh dưỡng ──────────────────────────────────────────

model HealthAssessment {
    assessment_id   Int      @id @default(autoincrement())
    student_id      Int
    school_year_id  Int
    class_id        Int? // lớp tại thời điểm đánh giá (BR-105)
    assessment_date DateTime
    height_cm       Float? // nullable — bản ghi rỗng tạo từ import dinh dưỡng (BR-138)
    weight_kg       Float?
    bmi             Float? // hệ thống tính, không nhập tay (BR-097/098)
    bmi_z           Float? // Z-score WHO
    height_z        Float?
    weight_z        Float?
    bmi_status      String?  @db.VarChar(50) // phân loại tiếng Việt (BR-110)
    height_status   String?  @db.VarChar(50)
    weight_status   String?  @db.VarChar(50)
    note            String?  @db.VarChar(500)
    created_by      Int?
    updated_by      Int?
    created_at      DateTime @default(now())
    updated_at      DateTime @updatedAt

    student     Student    @relation(fields: [student_id], references: [student_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])
    class       Class?     @relation(fields: [class_id], references: [class_id])

    @@unique([student_id, assessment_date]) // BR-090
    @@index([school_year_id])
    @@index([class_id])
    @@map("health_assessments")
}

// Đánh giá nuôi dưỡng — standalone, theo từng giai đoạn (đầu năm → cuối năm).
// Không gắn FK với HealthAssessment; giáo viên xem biểu đồ BMI để tham khảo khi đánh giá.
model NutritionAssessment {
    nutrition_id        Int      @id @default(autoincrement())
    student_id          Int
    school_year_id      Int
    class_id            Int?
    period              String   @db.VarChar(20) // dau_nam | giua_ky_1 | cuoi_ky_1 | dau_ky_2 | giua_ky_2 | cuoi_nam
    weight_channel      String?  @db.VarChar(50) // null=bình thường | 'Suy dinh dưỡng thể nhẹ cân' | 'Cân nặng cao hơn tuổi'
    is_stunting         Boolean  @default(false) // SDD thể thấp còi
    is_severe_stunting  Boolean  @default(false) // SDD thể còi cọc
    is_obese            Boolean  @default(false) // trẻ bị béo phì
    note                String?  @db.VarChar(500)
    created_by          Int?
    updated_by          Int?
    created_at          DateTime @default(now())
    updated_at          DateTime @updatedAt

    student     Student    @relation(fields: [student_id], references: [student_id])
    school_year SchoolYear @relation(fields: [school_year_id], references: [school_year_id])
    class       Class?     @relation(fields: [class_id], references: [class_id])

    @@unique([student_id, school_year_id, period]) // 1 bản ghi / học sinh / giai đoạn
    @@index([school_year_id, class_id, period])
    @@map("nutrition_assessments")
}
